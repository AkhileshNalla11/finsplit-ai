# ── Backend (backend/.env) ─────────────────────────────────────────────
# Anthropic Claude API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Model used for extraction. Defaults to claude-haiku-4-5 (cheap + fast — Claude
# only parses the description; all math is deterministic). Set to claude-sonnet-4-6
# for stronger reading on ambiguous descriptions.
CLAUDE_MODEL=

# ── OpenRouter (temporary alternative — keeps Anthropic creds intact) ──────────
# Set USE_OPENROUTER=true to route calls through OpenRouter instead of Anthropic.
# Get a key at https://openrouter.ai  |  Anthropic model slugs: https://openrouter.ai/models
# Leave blank to use Anthropic (default).
OPENROUTER_API_KEY=
USE_OPENROUTER=false
# Optional: override the model used via OpenRouter (default: anthropic/claude-haiku-3-5)
OPENROUTER_MODEL=

# Supabase project (Settings → API). Use the anon/public or service key.
SUPABASE_URL=
SUPABASE_KEY=

# Production frontend origin for CORS (e.g. https://finsplit.vercel.app).
# Optional locally; localhost:5173 is always allowed.
FRONTEND_ORIGIN=

# ── Frontend (frontend/.env) ───────────────────────────────────────────
# Base URL of the backend API. Defaults to http://localhost:8000 if unset.
VITE_API_URL=http://localhost:8000
